---
import { buildSocialLinks } from "@/lib/social-links";

interface Props {
  urls: Record<string, string>;
  class?: string;
  /** If set, only render these keys (e.g. `["googleScholar"]` on the publications page). */
  onlyKeys?: string[];
}

const { urls, class: className, onlyKeys } = Astro.props;
let socialLinks = buildSocialLinks(urls);
if (onlyKeys?.length) {
  const allow = new Set(onlyKeys);
  socialLinks = socialLinks.filter((l) => allow.has(l.key));
}
---

{
  socialLinks.length > 0 && (
    <nav
      class:list={[
        "flex flex-wrap items-center gap-1.5",
        className ?? "shrink-0 justify-end sm:justify-end",
      ]}
      aria-label="Social and web links"
    >
      {socialLinks.map(({ key, label, href }) => {
        const isMail = href.startsWith("mailto:");
        const external = !isMail;
        return (
          <a
            href={href}
            class="text-muted-foreground hover:bg-muted/80 hover:text-foreground inline-flex h-10 w-10 items-center justify-center rounded-md border border-transparent transition-colors hover:border-border"
            aria-label={label}
            target={external ? "_blank" : undefined}
            rel={external ? "noopener noreferrer" : undefined}
          >
            {key === "github" && (
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.311.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
                />
              </svg>
            )}
            {key === "linkedin" && (
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            )}
            {key === "website" && (
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
                <path d="M2 12h20" />
              </svg>
            )}
            {key === "googleScholar" && (
              <svg
                class="h-5 w-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" />
                <path d="M22 10v6" />
                <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5" />
              </svg>
            )}
            {key === "bluesky" && (
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 10.8c-1.087-2.114-4.046-6.053-6.38-6.053-3.264 0-5.926 2.65-5.926 5.92 0 3.266 2.662 5.915 5.926 5.915 2.334 0 5.293-3.94 6.38-6.053 1.087 2.113 4.046 6.053 6.38 6.053 3.264 0 5.926-2.649 5.926-5.915 0-3.27-2.662-5.92-5.926-5.92-2.334 0-5.293 3.939-6.38 6.053z" />
              </svg>
            )}
            {key === "twitter" && (
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            )}
            {key === "orcid" && (
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.934.934 0 0 1-.947-.947.93.93 0 0 1 .947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.876c3.004 0 4.734 1.789 4.734 4.898 0 3.14-1.773 4.966-4.803 4.966h-3.807V7.416zm1.444 1.303v7.259h1.737c2.04 0 3.197-1.08 3.197-3.63 0-2.32-1.096-3.629-3.08-3.629h-1.854z" />
              </svg>
            )}
            {!["github", "linkedin", "website", "googleScholar", "bluesky", "twitter", "orcid"].includes(
              key,
            ) &&
              (isMail ? (
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <rect width="20" height="16" x="2" y="4" rx="2" />
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                </svg>
              ) : (
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M15 3h6v6" />
                  <path d="M10 14 21 3" />
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                </svg>
              ))}
          </a>
        );
      })}
    </nav>
  )
}
