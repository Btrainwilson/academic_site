---
import type { ResearchDirection } from "@/types/data";
import { FlaskConical, Sigma, Cpu, ArrowRight } from "lucide-react";

interface Props {
  directions: ResearchDirection[];
}

const { directions } = Astro.props;

const iconMap: Record<string, typeof FlaskConical> = {
  FlaskConical,
  Sigma,
  Cpu,
};
---

<section class="not-prose mt-20" aria-labelledby="research-heading">
  <h2
    id="research-heading"
    class="text-foreground mb-8 text-2xl font-semibold tracking-tight"
  >
    Research directions
  </h2>

  <div class="grid gap-6 md:grid-cols-3">
    {
      directions.map((dir) => {
        const Icon = iconMap[dir.icon];
        return (
          <a
            href={`/research/${dir.id}`}
            class="group/card flex flex-col overflow-hidden rounded-xl bg-card text-sm text-card-foreground ring-1 ring-foreground/10 transition-shadow hover:ring-foreground/20 hover:shadow-md"
          >
            {/* Card image */}
            {dir.image && (
              <div class="overflow-hidden">
                <img
                  src={dir.image}
                  alt={dir.title}
                  class="h-36 w-full object-cover transition-transform duration-300 group-hover/card:scale-[1.02]"
                />
              </div>
            )}

            {/* Card body */}
            <div class="flex flex-1 flex-col gap-3 p-4">
              <div class="flex items-center gap-2.5">
                {Icon && (
                  <div class="flex size-8 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                    <Icon className="size-4" />
                  </div>
                )}
                <h3 class="font-heading text-base font-semibold leading-snug">
                  {dir.title}
                </h3>
              </div>

              <p class="text-muted-foreground text-sm leading-relaxed">
                {dir.description}
              </p>

              <div class="flex flex-wrap gap-1.5">
                {dir.tags.map((tag) => (
                  <span class="inline-flex h-5 items-center rounded-full bg-secondary px-2 text-xs font-medium text-secondary-foreground">
                    {tag}
                  </span>
                ))}
              </div>

              <div class="mt-auto pt-2">
                <span class="text-primary inline-flex items-center gap-1 text-sm font-medium group-hover/card:underline">
                  Learn more
                  <ArrowRight className="size-3.5 transition-transform group-hover/card:translate-x-0.5" />
                </span>
              </div>
            </div>
          </a>
        );
      })
    }
  </div>
</section>
