---
import type { ResearchDirection, ResearchHighlight } from "@/types/data";
import { ResearchHighlightsCarousel } from "@/components/landing/ResearchHighlightsCarousel";

interface Props {
  directions: ResearchDirection[];
  highlights: ResearchHighlight[];
}

const { directions, highlights } = Astro.props;

const directionTitles: Record<string, string> = {};
for (const d of directions) {
  directionTitles[d.id] = d.title;
}
---

<section class="not-prose mt-20" aria-labelledby="research-heading">
  <h2
    id="research-heading"
    class="text-foreground mb-8 text-2xl font-semibold tracking-tight"
  >
    Research Highlights
  </h2>

  {
    highlights.length > 0 && (
      <ResearchHighlightsCarousel
        client:visible
        highlights={highlights}
        directionTitles={directionTitles}
      />
    )
  }
</section>
